                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Banner, Interstitial Ads"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

